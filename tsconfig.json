{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@openio/shared": ["packages/shared/src/index.ts"],
      "@openio/ai": ["packages/ai/src/index.ts"],
      "@openio/agents": ["packages/agents/src/index.ts"],
      "@openio/memory": ["packages/memory/src/index.ts"],
      "@openio/tools": ["packages/tools/src/index.ts"],
      "@openio/mcp": ["packages/mcp/src/index.ts"],
      "@openio/project-engine": ["packages/project-engine/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}