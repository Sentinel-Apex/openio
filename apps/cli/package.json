    "@openio/tools": "workspace:*",
    "@openio/workspace-manager": "workspace:*",
    "@openio/plugin-system": "workspace:*",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-cursor": "^5.0.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "execa": "^9.0.0",
    "ink-progress-bar": "^3.0.0",
    "ink-select-input": "^5.0.0",
