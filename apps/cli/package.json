{
  "name": "@openio/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "openio": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openio/shared": "workspace:*",
    "@openio/ai": "workspace:*",
    "@openio/agents": "workspace:*",
    "@openio/memory": "workspace:*",
    "@openio/tools": "workspace:*",
    "@openio/mcp": "workspace:*",
    "@openio/project-engine": "workspace:*",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "chalk": "^5.3.0",
    "@inquirer/prompts": "^5.0.0",
    "ora": "^8.0.0",
    "cli-table3": "^0.6.3",
    "conf": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "ink": "^4.4.0",
    "ink-text-input": "^5.0.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
