{
  "name": "@openio/tools",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openio/shared": "workspace:*",
    "zod": "^3.22.0",
    "execa": "^9.0.0",
    "pg": "^8.11.0",
    "mysql2": "^3.9.0",
    "sql.js": "^1.10.0",
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.0",
    "@types/sql.js": "^1.4.0",

    "tsup": "^8.0.0",
    "typescript": "^5.5.4"
  }
}
